# Backend Dockerfile for LaunchPort Hosting Platform
# Node.js/Express API Server

FROM node:18

RUN apt-get update && apt-get install -y git lsof && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install production dependencies only
RUN npm install --production

# Copy all source code
COPY . .

# Expose port 5000
EXPOSE 5000

# Set environment variables
ENV NODE_ENV=production
ENV PORT=5000
ENV DATABASE_PATH=/data/platform.db

# Start the server
CMD ["npm", "start"]
